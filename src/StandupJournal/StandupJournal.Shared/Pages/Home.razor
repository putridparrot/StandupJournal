@code {
    private StandupEntry _activeEntry = new();
    private IReadOnlyList<StandupEntry> _recentEntries = [];
    private IReadOnlyList<StandupEntry> _lastSevenDays = [];
    private IReadOnlyList<string> _tags = [];
    private IReadOnlyList<string> _suggestions = [];
    private CancellationTokenSource? _autosaveCts;
    private string? _yesterdayPlan;
    private string? _carryovers;
    private string? _statusMessage;
    private bool _autoSaveEnabled = true;
    private int _mood = 3;

    private string MoodLabel => _mood switch
    {
        1 => "Low",
        2 => "Below average",
        3 => "Neutral",
        4 => "Good",
        5 => "Great",
        _ => "Neutral"
    };

    protected override async Task OnInitializedAsync()
    {
        AppPreferences.PreferencesChanged += OnPreferencesChanged;
        _recentEntries = await JournalService.GetRecentEntriesAsync(30);
        await LoadTodayAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AppPreferences.EnsureLoadedAsync(JS);
        _autoSaveEnabled = AppPreferences.AutoSaveEnabled;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadTodayAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        var yesterday = today.AddDays(-1);
        _activeEntry = await JournalService.GetOrCreateEntryForDateAsync(today);

        var yesterdayEntry = _recentEntries.FirstOrDefault(entry => entry.Date == yesterday);
        _yesterdayPlan = yesterdayEntry?.Today;
        _carryovers = BuildCarryovers(yesterdayEntry);
        if (string.IsNullOrWhiteSpace(_activeEntry.Yesterday) && !string.IsNullOrWhiteSpace(_carryovers))
        {
            _activeEntry.Yesterday = _carryovers;
        }

        RefreshContextPane();
        _statusMessage = null;
    }

    private async Task SaveEntryAsync()
    {
        await PersistEntryAsync(isAutoSave: false);
    }

    private Task OnYesterdayChangedAsync(string? value)
    {
        _activeEntry.Yesterday = value;
        QueueAutoSave();
        return Task.CompletedTask;
    }

    private Task OnTodayChangedAsync(string? value)
    {
        _activeEntry.Today = value;
        QueueAutoSave();
        return Task.CompletedTask;
    }

    private Task OnBlockersChangedAsync(string? value)
    {
        _activeEntry.Blockers = value;
        QueueAutoSave();
        return Task.CompletedTask;
    }

    private Task OnNotesChangedAsync(string? value)
    {
        _activeEntry.Notes = value;
        QueueAutoSave();
        return Task.CompletedTask;
    }

    private void QueueAutoSave()
    {
        if (!_autoSaveEnabled)
        {
            return;
        }

        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();

        _autosaveCts = new CancellationTokenSource();
        _ = AutoSaveAfterDelayAsync(_autosaveCts.Token);
    }

    private async Task AutoSaveAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(1200, cancellationToken);
            await PersistEntryAsync(isAutoSave: true);
        }
        catch (OperationCanceledException)
        {
            // Expected when user keeps typing.
        }
    }

    private async Task PersistEntryAsync(bool isAutoSave)
    {
        await JournalService.SaveAsync(_activeEntry);
        _statusMessage = isAutoSave
            ? $"Auto-saved at {DateTime.Now:t}"
            : $"Saved at {DateTime.Now:t}";

        UpsertEntry(_activeEntry);
        await InvokeAsync(StateHasChanged);
    }

    private void UpsertEntry(StandupEntry entry)
    {
        var updated = _recentEntries.ToList();
        var index = updated.FindIndex(item => item.Id == entry.Id || item.Date == entry.Date);

        var snapshot = new StandupEntry
        {
            Id = entry.Id,
            Date = entry.Date,
            Yesterday = entry.Yesterday,
            Today = entry.Today,
            Blockers = entry.Blockers,
            Notes = entry.Notes,
            UpdatedAtUtc = entry.UpdatedAtUtc
        };

        if (index >= 0)
        {
            updated[index] = snapshot;
        }
        else
        {
            updated.Add(snapshot);
        }

        _recentEntries = updated
            .OrderByDescending(item => item.Date)
            .Take(30)
            .ToList();

        RefreshContextPane();
    }

    private void RefreshContextPane()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        var start = today.AddDays(-6);

        _lastSevenDays = _recentEntries
            .Where(entry => entry.Date >= start && entry.Date <= today)
            .OrderByDescending(entry => entry.Date)
            .ToList();

        _tags = _recentEntries
            .Take(14)
            .SelectMany(entry => ExtractTags(entry.Notes))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(tag => tag)
            .Take(10)
            .ToList();

        _suggestions = BuildSuggestions().ToList();
    }

    private IEnumerable<string> BuildSuggestions()
    {
        var yesterday = DateOnly.FromDateTime(DateTime.Now).AddDays(-1);
        var yesterdayEntry = _recentEntries.FirstOrDefault(entry => entry.Date == yesterday);

        if (yesterdayEntry is null)
        {
            yield return "Add daily updates to unlock tailored suggestions.";
            yield break;
        }

        if (!string.IsNullOrWhiteSpace(yesterdayEntry.Blockers) && string.IsNullOrWhiteSpace(_activeEntry.Blockers))
        {
            yield return "You had a blocker yesterday — resolved?";
        }

        if (!string.IsNullOrWhiteSpace(yesterdayEntry.Today) && string.IsNullOrWhiteSpace(_activeEntry.Yesterday))
        {
            yield return "You planned work yesterday. Capture what was completed in 'What I did yesterday'.";
        }

        if (string.IsNullOrWhiteSpace(_activeEntry.Today))
        {
            yield return "Add at least one concrete plan for today.";
        }

        if (_mood <= 2)
        {
            yield return "Mood is low — consider adding a note on support needed.";
        }

        if (string.IsNullOrWhiteSpace(_activeEntry.Notes))
        {
            yield return "Optional: add notes with #tags to improve insights.";
        }
    }

    private static IEnumerable<string> ExtractTags(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes))
        {
            return [];
        }

        return notes.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(word => word.StartsWith('#') && word.Length > 1)
            .Select(word => word.Trim().TrimEnd(',', '.', ';', ':', '!', '?'));
    }

    private static string BuildPreview(StandupEntry entry)
    {
        var text = string.IsNullOrWhiteSpace(entry.Today) ? entry.Yesterday : entry.Today;
        if (string.IsNullOrWhiteSpace(text))
        {
            return "No content yet";
        }

        return text.Length <= 48 ? text : $"{text[..45]}...";
    }

    private static string? BuildCarryovers(StandupEntry? yesterdayEntry)
    {
        if (yesterdayEntry is null)
        {
            return null;
        }

        var carryovers = new List<string>();
        if (!string.IsNullOrWhiteSpace(yesterdayEntry.Today))
        {
            carryovers.Add(yesterdayEntry.Today.Trim());
        }

        if (!string.IsNullOrWhiteSpace(yesterdayEntry.Blockers))
        {
            carryovers.Add($"Blockers to revisit: {yesterdayEntry.Blockers.Trim()}");
        }

        return carryovers.Count == 0 ? null : string.Join(Environment.NewLine, carryovers);
    }

    public void Dispose()
    {
        AppPreferences.PreferencesChanged -= OnPreferencesChanged;
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
    }

    private void OnPreferencesChanged()
    {
        _autoSaveEnabled = AppPreferences.AutoSaveEnabled;
        _ = InvokeAsync(StateHasChanged);
    }
}
