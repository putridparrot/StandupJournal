@page "/"
@implements IDisposable
@inject IJSRuntime JS
@inject IStandupJournalService JournalService
@inject StandupJournal.Shared.Services.AppPreferencesService AppPreferences

<PageTitle>Today</PageTitle>

<div class="stack" >
    <FluentCard class="editor-card">
        <FluentLabel Typography="Typography.Title2">@_activeEntry.Date.ToString("dddd, MMM dd yyyy")</FluentLabel>

        <div class="summary-item">
            <FluentLabel class="summary-label">Yesterday’s carryovers</FluentLabel>
            @if (string.IsNullOrWhiteSpace(_carryovers))
            {
                <FluentLabel class="muted-text">No carryovers from yesterday.</FluentLabel>
            }
            else
            {
                <p class="history-text">@_carryovers</p>
            }
        </div>

        <div class="editor-grid">
            <FluentTextArea Label="What I did yesterday" Rows="4" Value="@_activeEntry.Yesterday" ValueChanged="OnYesterdayChangedAsync" />
            <FluentTextArea Label="What I plan to do today" Rows="4" Value="@_activeEntry.Today" ValueChanged="OnTodayChangedAsync" />
            <FluentTextArea Label="Blockers" Rows="3" Value="@_activeEntry.Blockers" ValueChanged="OnBlockersChangedAsync" />
            <FluentTextArea Label="Notes (optional)" Rows="3" Value="@_activeEntry.Notes" ValueChanged="OnNotesChangedAsync" />
        </div>

        @if (!_autoSaveEnabled)
        {
            <div class="action-row">
                <FluentButton Appearance="Appearance.Accent" @onclick="SaveEntryAsync">Save Entry</FluentButton>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <FluentLabel class="status-text">@_statusMessage</FluentLabel>
        }
    </FluentCard>

